{
  "expo": {
    "name": "Napas DayOne",
    "slug": "napas-dayone-demo",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lsm.pay",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lsm.pay",
      "adaptiveIcon": {
        "backgroundColor": "#F4F7FB"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Cho phép Napas DayOne sử dụng Face ID để xác thực đăng nhập."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Cho phép Napas DayOne sử dụng camera trước để xác minh khuôn mặt.",
          "recordAudioAndroid": false
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "ad101dc5-d4f2-443f-a46f-1348d415ea8e"
      }
    }
  }
}
